# Copy this file to .env and fill in real values.
# Never commit the .env file (it is in .gitignore).

# UTSA LLM server credentials
UTSA_API_KEY=replace-with-your-utsa-key
UTSA_BASE_URL=http://149.165.173.247:8888/v1
UTSA_MODEL=meta-llama/Llama-3.1-8B-Instruct

# Optional: tune the offline TTS voice
TTS_ENABLED=true
TTS_RATE=175
TTS_VOLUME=1.0
