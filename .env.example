# =========================
# Restaurant Voice Ordering Agent Environment
# =========================

# Flask / runtime
ENV=development
DEBUG=false
LOG_LEVEL=INFO
JSON_LOGS=true
REQUEST_ID=true

# App
RESTAURANT_NAME=Paoli's Pizza Palace
TAX_RATE=0.08

# LLM / OpenAI-compatible endpoint
# Required only for live LLM-backed intent parsing and RAG generation.
# For local/offline tests, set MOCK_LLM=true if supported by the test setup.
UTSA_BASE_URL=http://149.165.173.247:8888/v1

#ENTER API KEY HERE
UTSA_API_KEY=EMPTY 

UTSA_MODEL=meta-llama/Llama-3.1-8B-Instruct
PARSER_MODEL=meta-llama/Llama-3.1-8B-Instruct

# Retrieval / Chroma
EMBED_MODEL=all-MiniLM-L6-v2
RETRIEVAL_TOP_K=8
SIMILARITY_THRESHOLD=0.30
CHROMA_COLLECTION_NAME=pizza_menu
CHROMA_DISTANCE_METRIC=cosine
EMBEDDING_DEVICE=cpu
NORMALIZE_EMBEDDINGS=true

# Paths
MENU_PATH=data/menu/menu.json
CHROMA_STORE=data/vector_store/chroma_db
KNOWLEDGE_CHUNKS_PATH=data/knowledge/knowledge_chunks.json
LOG_DIR=logs

# Conversation defaults
DEFAULT_CRUST=hand tossed
DEFAULT_PIZZA_SIZE=medium
DEFAULT_PIZZA_BASE=cheese
DEFAULT_WING_SIZE=6 piece
MAX_TURNS=20
REQUIRE_CONFIRMATION=true

# Voice mode
# Twilio voice mode does not require local ASR/TTS.
# Twilio handles speech recognition and text-to-speech through /voice.
ASR_ENABLED=true
TTS_ENABLED=false
VOICE_SAMPLE_RATE=16000
VOICE_CHANNELS=1
TTS_RATE=175
TTS_VOLUME=1.0

# Testing
MOCK_LLM=false
